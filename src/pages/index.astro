---
import SiteLayout from "../layouts/SiteLayout.astro";
const images = [
  "/P1.png",
  "/P2.png",
  "/P3.png",
  "/P4.png",
  "/P5.png",
];
import "../css/HomePage.css";
---


<SiteLayout title="ΑΡΝΟΚΟΥΡΟΣ" subTitle="ΑΝΔΡΙΚΗ ΕΝΔΥΣΗ" date="1973">
<div class="flex flex-col items-center justify-center min-h-screen bg-base-200 p-4 ">
  <div class="text-center mb-10">
<h1
  class="text-4xl md:text-5xl font-bold text-center text-base-content mb-3"
  data-i18n="Title1"
></h1>

  <div class="w-20 h-1 bg-primary mx-auto mt-4 rounded-full"></div>
</div>
<p class="text-center text-base-content/70 max-w-2xl mx-auto mb-10" data-i18n="subTitle1">
  Discover timeless men's fashion designed for confidence, comfort, and everyday style.
</p>


<div class="overflow-hidden w-full py-8">
  <div class="slider-track">
    {[...images, ...images].map((image) => (
      <img
        src={image}
        alt=""
        class="w-80 h-96 object-cover rounded-xl mx-4 flex-shrink-0"
      />
    ))}
  </div>
</div>

  </div>
  <div class="hero bg-base-200 min-h-screen">
    <div class="hero-content flex-col lg:flex-row-reverse">
      <div class="dark:hidden">
        <img
          src="/ArnokourosLightP2.jpg"
          alt="Arnokouros Building"
          class="max-w-sm rounded-lg shadow-2xl"
        />
      </div>
      <div class="dark:block hidden">
        <img
          src="/ArokourosNight.png"
          alt="Arnokouros Building"
          class="max-w-sm rounded-lg shadow-2xl"
        />
      </div>
      <div>
        <h1 class="md:text-5xl font-bold underline text-3xl font-bold underline"  data-i18n="Title2">About Us</h1>
        <p class="py-6" data-i18n="MainInfo"></p>
        <button class="btn btn-primary" data-i18n="ContactBtn2">Επικοινωνήστε</button>
      </div>
    </div>
  </div>

  <div class="flex justify-center p-8">
     <h1 class="text-2xl font-bold underline md:text-5xl font-bold underline"  data-i18n="Location2"></h1>
  </div>
  <div class="max-w-2xl mx-auto bg-white dark:bg-gray-800 rounded-2xl shadow-xl overflow-hidden border border-gray-100 dark:border-gray-700">
    <div class="relative w-full h-64 sm:h-80 bg-gray-100">
        <iframe 
            class="absolute top-0 left-0 w-full h-full border-0"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d227.07833971664277!2d23.728789856231245!3d37.9838172143795!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14a1bd343263a88b%3A0x6f293fa6459a3cb!2zzpHOoc6dzp_Oms6fzqXOoc6fzqMgzpHOnc6UzqHOmc6azpcgzpXOnc6UzqXOo86X!5e0!3m2!1sel!2sgr!4v1782122821044!5m2!1sel!2sgr" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
        </iframe>
    </div>

    <div class="p-6">
        <div class="flex items-center gap-2 text-xs font-bold text-yellow-600 dark:text-yellow-500 uppercase tracking-wider mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <p data-i18n="LocationInfo">
        
           </p>
        </div>
        
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
            ΑΡΝΟΚΟΥΡΟΣ ΑΝΔΡΙΚΗ ΕΝΔΥΣΗ
        </h3>

        <div class="mt-5 flex justify-end">
            <a 
                href="https://maps.app.goo.gl/f5JmaCojJxbkWubW6" 
                target="_blank" 
                class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-gray-900 hover:bg-gray-800 dark:bg-yellow-500 dark:text-gray-950 dark:hover:bg-yellow-400 rounded-lg transition-colors shadow-sm"
            >
                Google Maps
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
            </a>
        </div>
    </div>
</div>
</SiteLayout>
