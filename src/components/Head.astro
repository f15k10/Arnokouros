---
import "../styles/global.css";
const { title, subTitle, date } = Astro.props;
---

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <div class="flex justify-evenly">
        <div class="order-2 content-center md:hidden">Hello</div>
        <div class="flex flex-col gap-2 order-1 my-8 px-8">
            <p
                class="font-serif text-yellow-600 text-2xl font-stretch-150% font-bold underline decoration-yellow-600 decoration-2 underline-offset-4"
            >
                {title}
            </p>
            <div
                class="flex flex-col sm:flex-row sm:items-center sm:justify-end gap-2 text-sm text-gray-600"
            >
                <span
                    class="font-semibold leading-6 dark:text-white"
                    data-i18n="subTitle">{subTitle}</span
                >
                <span class="hidden sm:inline" aria-hidden="true">•</span>
                <span class="dark:text-white">{date}</span>
            </div>
        </div>
        <div class="order-2 my-8 content-center hidden md:block">
            <nav
                class="bg-stone-200 dark:bg-stone-800 shadow-xl/30 px-8 py-8 rounded-full"
            >
                <div
                    class="flex gap-x-16 px-8 antialiased md:subpixel-antialiased font-medium"
                >
                    <a
                        href="#"
                        class="font-semibold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transform hover:scale-105 transition-all duration-300 ease-in-out"
                        data-i18n="Home"
                        >Home
                    </a>
                    <a
                        href="#"
                        class="font-semibold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transform hover:scale-105 transition-all duration-300 ease-in-out"
                        data-i18n="Clothes"
                    >
                        Clothes
                    </a>
                    <a
                        href="#"
                        class="font-semibold text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transform hover:scale-105 transition-all duration-300 ease-in-out"
                        data-i18n="Contact">Contact</a
                    >
                </div>
            </nav>
        </div>
        <div
            class="order-3 my-8 px-8 content-center flex items-center gap-2 hidden md:block"
        >
            <label class="swap swap-rotate btn btn-ghost btn-circle">
                <input
                    type="checkbox"
                    class="theme-controller dark-theme-toggle"
                />

                <svg
                    class="swap-on fill-current w-6 h-6"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                >
                    <path
                        d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"
                    ></path>
                </svg>

                <svg
                    class="swap-off fill-current w-6 h-6"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                >
                    <path
                        d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"
                    ></path>
                </svg>
                <span class="sr-only">Toggle dark or light mode</span>
            </label>
            <button
                class="btn btn-ghost btn-circle font-bold text-sm lang-cycle-btn"
                aria-label="Change language"
            >
                <span class="lang-label">EN</span>
            </button>
        </div>
        <div class="content-center md:hidden">
            <ul class="menu bg-base-200 rounded-box">
                <li>
                    <label class="swap swap-rotate btn btn-ghost btn-circle">
                        <input
                            type="checkbox"
                            class="theme-controller dark-theme-toggle"
                        />

                        <svg
                            class="swap-on fill-current w-6 h-6"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"
                            ></path>
                        </svg>

                        <svg
                            class="swap-off fill-current w-6 h-6"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"
                            ></path>
                        </svg>
                        <span class="sr-only">Toggle dark or light mode</span>
                    </label>
                </li>
                <li>
                    <button
                        class="btn btn-ghost btn-circle font-bold text-sm lang-cycle-btn"
                        aria-label="Change language"
                    >
                        <span class="lang-label">EN</span>
                    </button>
                </li>
            </ul>
        </div>
    </div>
</head>
<script is:inline>
    const getTheme = () => {
        if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
        ) {
            return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
    };

    const currentTheme = getTheme();

    document.documentElement.setAttribute("data-theme", currentTheme);

    const setupToggle = () => {
        const toggles = document.querySelectorAll(".dark-theme-toggle");

        toggles.forEach((toggle) => {

            toggle.checked = currentTheme === "light";

            toggle.addEventListener("change", (e) => {
                const themeToSet = e.target.checked ? "light" : "dark";
                document.documentElement.setAttribute("data-theme", themeToSet);
                localStorage.setItem("theme", themeToSet);

                const allToggles =
                    document.querySelectorAll(".dark-theme-toggle");
                allToggles.forEach((t) => {
                    t.checked = e.target.checked;
                });
            });
        });
    };

    setupToggle();

    const languages = ["EN", "GR", "CN"];
    let currentLangIndex = languages.indexOf(
        localStorage.getItem("lang") || "EN",
    );
    if (currentLangIndex === -1) currentLangIndex = 0;

    const langBtns = document.querySelectorAll(".lang-cycle-btn");
    const langLabels = document.querySelectorAll(".lang-label");

    let translations = {};

    const translatePage = (langCode) => {
        const key = langCode.toLowerCase();
        const elements = document.querySelectorAll("[data-i18n]");

        elements.forEach((element) => {
            const translationId = element.getAttribute("data-i18n");
            if (translations[key] && translations[key][translationId]) {
                element.textContent = translations[key][translationId];
            }
        });
    };

    async function loadTranslations() {
        try {
            const response = await fetch("/Translate.json");
            translations = await response.json();

            translatePage(languages[currentLangIndex]);
        } catch (error) {
            console.error("Could not load public/locales.json file:", error);
        }
    }

    langLabels.forEach((label) => {
        label.textContent = languages[currentLangIndex];
    });

    loadTranslations();

    langBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            currentLangIndex = (currentLangIndex + 1) % languages.length;
            const newLang = languages[currentLangIndex];

            langLabels.forEach((label) => {
                label.textContent = newLang;
            });

            translatePage(newLang);
            localStorage.setItem("lang", newLang);
        });
    });
</script>
